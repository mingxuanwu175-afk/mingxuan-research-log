---
import type { HTMLAttributes } from 'astro/types';
import { withBase, withoutBase } from '../utils/paths';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizedHref = typeof href === 'string' ? href : '/';
const pathname = withoutBase(Astro.url.pathname);
const isActive =
  pathname === normalizedHref ||
  pathname.startsWith(normalizedHref === '/' ? '/#' : normalizedHref + '/');
---

<a
  href={withBase(normalizedHref)}
  aria-current={isActive ? 'page' : undefined}
  class:list={['nav-link', className, { active: isActive }]}
  {...props}
>
  <slot />
</a>

<style>
.nav-link {
  display: inline-flex;
  align-items: center;
  padding: 0;
  font-size: var(--text-caption-1);
  font-weight: var(--weight-regular);
  color: var(--label-secondary);
  text-decoration: none;
  transition:
    color var(--duration-fast) var(--ease-out),
    opacity var(--duration-fast) var(--ease-out);
}

.nav-link:hover {
  color: var(--label-primary);
  font-weight: var(--weight-semibold);
  opacity: 0.72;
}

.nav-link.active {
  color: var(--label-primary);
  font-weight: var(--weight-semibold);
}
</style>
