---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import config from '../../astro-theme-config';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR, SITE_LOCALE } from '../consts';
import { withBase } from '../utils/paths';
import { serializeScriptJson } from '../utils/serialize-script-json';

// Enable with PUBLIC_VERCEL_ANALYTICS=true.
const analyticsEnabled = import.meta.env.PUBLIC_VERCEL_ANALYTICS === 'true';
const commentsMode = import.meta.env.PUBLIC_GISCUS_MODE || config.comments.mode;
const commentsEnabled = commentsMode === 'giscus' || commentsMode === 'giscus-custom';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  /** Pre-built OG image URL string — overrides image.src when provided */
  ogImageUrl?: string;
  /** 'website' (default) | 'article' */
  type?: 'website' | 'article';
  /** ISO date string — article published_time */
  pubDate?: string;
  /** ISO date string — article modified_time */
  updatedDate?: string;
  /** Robots meta content. Defaults to public indexing. */
  robots?: string;
  /** Canonical URL override for special routes such as 404.html. */
  canonicalUrl?: string;
  /** Social URL override for special routes such as 404.html. */
  pageUrl?: string;
  /** Open Graph locale override for localized routes. */
  locale?: string;
}

const {
  title,
  description,
  image,
  ogImageUrl,
  type = 'website',
  pubDate,
  updatedDate,
  robots = 'index, follow',
  canonicalUrl,
  pageUrl,
  locale,
} = Astro.props;

const canonicalURL = canonicalUrl
  ? new URL(canonicalUrl, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const ogLocale = locale ?? SITE_LOCALE;
const documentTitle = title === SITE_TITLE ? title : `${title} — ${SITE_TITLE}`;
const fallbackOgImageUrl = config.site.defaultOgImage;
const ogImage = ogImageUrl
  ? new URL(withBase(ogImageUrl), Astro.site)
  : image
    ? new URL(image.src, Astro.url)
    : fallbackOgImageUrl
      ? new URL(withBase(fallbackOgImageUrl), Astro.site)
      : null;
const canonicalHref = canonicalURL.toString();
const siteHref = new URL(withBase('/'), Astro.site).toString();
const searchHref = new URL(withBase('/search'), Astro.site).toString();
const rssHref = new URL(withBase('/rss.xml'), Astro.site).toString();
const sitemapHref = new URL(withBase('/sitemap-index.xml'), Astro.site).toString();
const pageHref = pageUrl ? new URL(pageUrl, Astro.site).toString() : Astro.url.toString();
const ogImageHref = ogImage?.toString();

// WebSite JSON-LD for website pages only.
const websiteJsonLd =
  type === 'website'
    ? serializeScriptJson({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_TITLE,
        description: SITE_DESCRIPTION,
        url: siteHref,
        author: { '@type': 'Person', name: SITE_AUTHOR },
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: `${searchHref}?q={search_term_string}`,
          },
          'query-input': 'required name=search_term_string',
        },
      })
    : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Theme init — runs early to prevent FOUC -->
<script is:inline>
  (function () {
    let d;
    try {
      d = localStorage.getItem('theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    } catch {
      d = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    const el = document.documentElement;
    el.setAttribute('data-theme', d);
    el.classList.add('no-transitions');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () { el.classList.remove('no-transitions'); });
    });
  })();
</script>

<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} sizes="any" />
<link rel="icon" type="image/png" href={withBase('/favicon-32x32.png')} sizes="32x32" />
<link rel="icon" type="image/png" href={withBase('/favicon-16x16.png')} sizes="16x16" />
<link rel="shortcut icon" href={withBase('/favicon.ico')} />
<link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
<link rel="sitemap" href={sitemapHref} />
{
  commentsEnabled && (
    <>
      <link rel="preconnect" href="https://giscus.app" crossorigin />
      <link rel="preconnect" href="https://github.com" crossorigin />
      <link rel="preload" href="https://giscus.app/client.js" as="script" crossorigin />
    </>
  )
}
<meta name="theme-color" content="#f7fbfd" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
<link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={rssHref} />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={robots} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{documentTitle}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE_AUTHOR} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={pageHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageHref && <meta property="og:image" content={ogImageHref} />}
{ogImageHref && <meta property="og:image:width" content={String(image?.width ?? 1200)} />}
{ogImageHref && <meta property="og:image:height" content={String(image?.height ?? 630)} />}
{ogImageHref && <meta property="og:image:alt" content={title} />}
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={SITE_TITLE} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate} />}
{
  type === 'article' && updatedDate && (
    <meta property="article:modified_time" content={updatedDate} />
  )
}
{type === 'article' && <meta property="article:author" content={SITE_AUTHOR} />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={pageHref} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
{ogImageHref && <meta name="twitter:image:alt" content={title} />}

<!-- JSON-LD (WebSite schema) -->
{websiteJsonLd && <script is:inline type="application/ld+json" set:html={websiteJsonLd} />}

<!-- Vercel Analytics (opt-in: PUBLIC_VERCEL_ANALYTICS=true) -->
{analyticsEnabled && <script is:inline defer src="/_vercel/insights/script.js" />}
