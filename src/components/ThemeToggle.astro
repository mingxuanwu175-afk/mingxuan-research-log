---

<button
  type="button"
  class="theme-toggle"
  id="theme-toggle"
  aria-label="Toggle dark mode"
  aria-pressed="false"
  title="Toggle dark mode"
>
  <svg
    class="theme-icon"
    xmlns="http://www.w3.org/2000/svg"
    width="19"
    height="19"
    viewBox="0 0 20 20"
    aria-hidden="true"
  >
    <circle class="theme-icon-ring" cx="10" cy="10" r="6.75"></circle>
    <path class="theme-icon-phase" d="M10 3.25a6.75 6.75 0 0 1 0 13.5 3.65 6.75 0 0 0 0-13.5Z"
    ></path>
  </svg>
</button>

<script is:inline>
  (function () {
    function mountThemeToggle() {
      const root = document.documentElement;
      const btn = document.getElementById('theme-toggle');
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.themeReady === 'true') return;
      btn.dataset.themeReady = 'true';

      const syncAriaPressed = (dark) => {
        btn.setAttribute('aria-pressed', String(dark));
        btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
      };

      syncAriaPressed(root.getAttribute('data-theme') === 'dark');

      btn.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch {
          // Keep the visible toggle working when storage is unavailable.
        }
        syncAriaPressed(next === 'dark');
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountThemeToggle, { once: true });
    } else {
      mountThemeToggle();
    }
  })();
</script>

<style>
.theme-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--label-secondary);
  transition:
    color var(--duration-fast) var(--ease-out),
    opacity var(--duration-fast) var(--ease-out);
  flex-shrink: 0;
}

.theme-toggle:hover {
  color: var(--label-primary);
}

.theme-toggle:focus-visible {
  outline: 1px solid currentColor;
  outline-offset: 0.25rem;
}

.theme-icon {
  display: block;
  overflow: visible;
  transition: transform var(--duration-normal) var(--ease-out);
}

.theme-icon-ring {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.45;
}

.theme-icon-phase {
  fill: currentColor;
  opacity: 0.62;
  transform-origin: center;
  transition: opacity var(--duration-fast) var(--ease-out);
}

:global([data-theme='dark']) .theme-icon {
  transform: rotate(180deg);
}

:global([data-theme='dark']) .theme-icon-phase {
  opacity: 0.76;
}
</style>
