---
import config from '../../astro-theme-config';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { withBase } from '../utils/paths';

const skipLinkLabel = 'Skip to content';
const navAriaLabel = 'Primary navigation';
const headerTitle = config.site.logoLabel || config.site.title;
const navItems = config.nav;
---

<a href="#main-content" class="skip-link" tabindex="0">{skipLinkLabel}</a>
<header class="site-header glass">
  <nav class="nav-inner" aria-label={navAriaLabel}>
    <a href={withBase('/')} class="nav-logo">{headerTitle}</a>
    <div class="nav-right">
      <div class="nav-links">
        {navItems.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
      </div>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    function mountAutoHideHeader() {
      const header = document.querySelector('.site-header');
      if (!(header instanceof HTMLElement) || header.dataset.scrollReady === 'true') return;
      header.dataset.scrollReady = 'true';

      let lastY = window.scrollY;
      let ticking = false;

      const sync = () => {
        const currentY = window.scrollY;
        const delta = currentY - lastY;
        const activeElement = document.activeElement;
        const hasKeyboardFocus =
          activeElement instanceof HTMLElement &&
            header.contains(activeElement) &&
            activeElement.matches(':focus-visible');

        header.classList.toggle('is-scrolled', currentY > 8);

        if (currentY < 24 || hasKeyboardFocus) {
          header.classList.remove('is-hidden');
        } else if (delta > 8 && currentY > 96) {
          header.classList.add('is-hidden');
        } else if (delta < -8) {
          header.classList.remove('is-hidden');
        }

        lastY = currentY;
        ticking = false;
      };

      sync();

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            window.requestAnimationFrame(sync);
            ticking = true;
          }
        },
        { passive: true }
      );
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountAutoHideHeader, { once: true });
    } else {
      mountAutoHideHeader();
    }
  })();
</script>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  height: var(--nav-height);
  border-bottom: none;
  background-color: var(--bg-primary);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  transform: translateY(0);
  transition:
    transform var(--duration-normal) var(--ease-out),
    background-color var(--duration-fast) var(--ease-out);
  will-change: transform;
}

.site-header.glass {
  background-color: var(--bg-primary);
}

:global([data-theme='dark']) .site-header.glass,
:global(:root:not([data-theme='light'])) .site-header.glass {
  background-color: var(--bg-primary);
}

.site-header.glass.is-scrolled {
  background-color: color-mix(in srgb, var(--bg-primary) 88%, transparent);
}

:global([data-theme='dark']) .site-header.glass.is-scrolled {
  background-color: color-mix(in srgb, var(--bg-primary) 82%, transparent);
}

.site-header.is-hidden {
  transform: translateY(calc(-1 * var(--nav-height)));
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: var(--max-width-wide);
  margin: 0 auto;
  padding: 0 var(--space-6);
  height: 100%;
}

.nav-logo {
  font-size: var(--text-headline);
  font-weight: var(--weight-semibold);
  color: var(--label-primary);
  text-decoration: none;
  letter-spacing: var(--tracking-tight);
  transition:
    color var(--duration-fast) var(--ease-out),
    opacity var(--duration-fast) var(--ease-out);
}

.nav-logo:hover {
  opacity: 0.7;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: var(--space-5);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

@media (min-width: 55rem) {
  .nav-right {
    margin-right: calc(var(--max-width-wide) - var(--max-width-content) - var(--space-12));
  }
}

@media (max-width: 600px) {
  .nav-inner {
    padding: 0 var(--space-4);
  }

  .nav-right {
    gap: var(--space-3);
    margin-right: 0;
  }

  .nav-links {
    gap: var(--space-3);
  }
}

@media (prefers-reduced-motion: reduce) {
  .site-header {
    transition: none;
  }
}
</style>
