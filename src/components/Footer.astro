---
import config from '../../astro-theme-config';
import { withBase } from '../utils/paths';

const today = new Date();
const footerTitle = config.site.logoLabel || config.site.title;
const footerLinks = config.footerNav.filter((item) => item.href !== '/');
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-copy">
      &copy; {today.getFullYear()}
      {footerTitle}.
    </p>
    {
      footerLinks.length > 0 && (
        <nav class="footer-links" aria-label="Footer navigation">
          {footerLinks.map((item) => (
            <a
              href={withBase(item.href)}
              data-search-palette-trigger={item.href === '/search' ? 'true' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      )
    }
  </div>
</footer>

<style>
.site-footer {
  background: transparent;
  padding: var(--space-4) 0 var(--space-10);
  margin-top: var(--space-12);
}

.footer-inner {
  max-width: var(--max-width-wide);
  margin: 0 auto;
  padding: 0 var(--space-6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-6);
  flex-wrap: wrap;
}

.footer-copy {
  font-size: var(--text-footnote);
  color: var(--label-tertiary);
  margin: 0;
}

.footer-links {
  display: flex;
  gap: var(--space-5);
}

.footer-links a,
.footer-links button {
  font-size: var(--text-footnote);
  color: var(--label-tertiary);
  font-family: inherit;
  font-weight: inherit;
  line-height: inherit;
  text-decoration: none;
  border: 0;
  padding: 0;
  background: transparent;
  cursor: pointer;
  transition: color var(--duration-fast) var(--ease-out);
}

.footer-links a:hover,
.footer-links button:hover {
  color: var(--label-primary);
  opacity: 1;
}

@media (min-width: 55rem) {
  .footer-links {
    margin-right: calc(var(--max-width-wide) - var(--max-width-content) - var(--space-12));
  }
}

@media (max-width: 600px) {
  .site-footer {
    margin-top: var(--space-10);
  }

  .footer-inner {
    padding: 0 var(--space-4);
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    text-align: left;
  }

  .footer-links {
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-right: 0;
  }
}

@media (max-width: 340px) {
  .footer-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
